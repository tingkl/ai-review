#!/bin/bash
# AI Code Review Hook — generated by commit-ai-guardian
# 此文件由 commit-ai-guardian install 自动生成，请勿手动修改

# === 定位仓库根目录 ===
# SCRIPT_DIR = .git/hooks/ 的绝对路径
# REPO_ROOT  = 往上退两级，到仓库根目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

# === 运行 AI 代码审核 ===
# 优先用 uv（如果有的话），否则回退到系统 python
if command -v uv &> /dev/null; then
    # uv run：在 ai-review 项目的虚拟环境中执行
    uv run --python-preference only-managed python -m commit_ai_guardian audit --repo "$REPO_ROOT"
else
    python -m commit_ai_guardian audit --repo "$REPO_ROOT"
fi

# === 透传退出码 ===
# Python 返回 0 → commit 放行
# Python 返回 1 → commit 被阻断（AI 发现了严重问题）
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "提示: 使用 git commit --no-verify 跳过 AI 审核（不推荐）"
    exit $EXIT_CODE   # ← 把退出码传给 Git，决定 commit 是否放行
fi

exit 0
